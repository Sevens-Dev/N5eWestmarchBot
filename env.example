# ===== Discord =====
# Get from https://discord.com/developers/applications -> Your App -> Bot -> Reset Token
DISCORD_BOT_TOKEN=

# Comma-separated Discord user IDs allowed to run !auction
AUTHORIZED_USER_IDS=111111111111111111,222222222222222222

# Channel IDs (right-click channel in Discord with Developer Mode on -> Copy ID)
SUPPORT_CHANNEL_ID=
AUCTION_CHANNEL_ID=

# Comma-separated ROLE NAMES allowed to use !createplayer
CREATEPLAYER_ROLES=Gamemaster

# ===== Google Sheets =====
SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
GOOGLE_CREDENTIALS_PATH=./credentials.json
AUCTION_RESOURCE_BOOK=LMAO Resources
